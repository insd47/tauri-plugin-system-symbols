{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist-js",
    "rootDir": "guest-js",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["guest-js/**/*.ts"]
}
